---
layout: base.njk
title: Journal
description: Honest writing about graduate school life — research, burnout, identity, and the things nobody tells you.
---
{% from "macros.njk" import postCard %}

<div class="journal-page">
  <div class="page-header">
    <div class="container">
      <div class="page-header-inner">
        <h1 class="page-title">My Writing</h1>
        <p class="page-description">These are my honest reflections on graduate school — the hard parts, the unexpected parts, the parts I needed to name out loud. No advice. No performance. Just what was true.</p>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="journal-toolbar">
      {# Search #}
      <div class="search-row" style="margin-bottom: var(--space-6);">
        <div class="search-input-wrap">
          <svg class="search-icon" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            type="search"
            class="search-input"
            id="journal-search"
            placeholder="Search posts..."
            aria-label="Search journal posts"
          />
        </div>
      </div>

      {# Category filter chips #}
      <div class="filter-chips" id="category-chips" role="group" aria-label="Filter by category">
        <button class="chip is-active" data-category="all">All</button>
        {% for category in site.categories %}
        <button class="chip" data-category="{{ category }}">{{ category }}</button>
        {% endfor %}
      </div>
    </div>

    {% if collections.blogPosts and collections.blogPosts.length > 0 %}
    <div class="card-grid" id="journal-grid">
      {% for post in collections.blogPosts %}
      <a href="{{ post.url }}"
         class="card post-card"
         data-title="{{ post.data.title | lower }}"
         data-excerpt="{{ post.data.excerpt | lower }}"
         data-category="{{ post.data.category }}">
        {% if post.data.category %}
        <span class="tag tag--category">{{ post.data.category }}</span>
        {% endif %}
        <h2 class="card-title">{{ post.data.title }}</h2>
        {% if post.data.excerpt %}
        <p class="card-excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
        <div class="card-meta">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | formatDate }}</time>
          <span class="meta-sep">&middot;</span>
          <span>{{ post.templateContent | readingTime }}</span>
        </div>
      </a>
      {% endfor %}
    </div>

    <div class="empty-state" id="journal-no-results" style="display: none;">
      <div class="empty-state-icon" aria-hidden="true">◌</div>
      <h3>No posts match</h3>
      <p>Try a different search term or category.</p>
    </div>

    {% else %}
    <div class="empty-state">
      <div class="empty-state-icon" aria-hidden="true">✦</div>
      <h3>Your writing will live here</h3>
      <p>When you publish your first journal post, it will appear in this grid. Go to <strong>/admin</strong>, open Journal Posts, and when you are ready to publish, toggle Draft off.</p>
    </div>
    {% endif %}
  </div>
</div>

<script>
(function() {
  const searchInput = document.getElementById("journal-search");
  const chips = document.querySelectorAll("#category-chips .chip");
  const cards = document.querySelectorAll("#journal-grid .post-card");
  const noResults = document.getElementById("journal-no-results");
  const grid = document.getElementById("journal-grid");

  let activeCategory = "all";
  let searchTerm = "";

  function filterCards() {
    let visible = 0;
    cards.forEach(function(card) {
      const title = card.getAttribute("data-title") || "";
      const excerpt = card.getAttribute("data-excerpt") || "";
      const category = card.getAttribute("data-category") || "";
      const matchesSearch = !searchTerm || title.includes(searchTerm) || excerpt.includes(searchTerm);
      const matchesCategory = activeCategory === "all" || category === activeCategory;
      if (matchesSearch && matchesCategory) {
        card.style.display = "";
        visible++;
      } else {
        card.style.display = "none";
      }
    });
    if (noResults) {
      noResults.style.display = visible === 0 ? "block" : "none";
    }
    if (grid) {
      grid.style.display = visible === 0 ? "none" : "";
    }
  }

  if (searchInput) {
    searchInput.addEventListener("input", function() {
      searchTerm = this.value.trim().toLowerCase();
      filterCards();
    });
  }

  chips.forEach(function(chip) {
    chip.addEventListener("click", function() {
      chips.forEach(function(c) { c.classList.remove("is-active"); });
      chip.classList.add("is-active");
      activeCategory = chip.getAttribute("data-category");
      filterCards();
    });
  });
})();
</script>
