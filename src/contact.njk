---
layout: base.njk
title: Contact
description: Get in touch with Saudade — questions, feedback, or just to say hello.
---

<div class="contact-page">
  <div class="page-header">
    <div class="container">
      <div class="page-header-inner">
        <h1 class="page-title">Get in Touch</h1>
        <p class="page-description">Questions, thoughts, feedback, or anything else. There is a real person on the other end of this. No automated responses.</p>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="contact-layout">

      {# Left — form #}
      <div class="contact-main">
        <form id="contact-form" novalidate>
          <div class="form-group">
            <label class="form-label" for="contact-name">Name <span class="optional">(optional)</span></label>
            <input type="text" class="form-input" id="contact-name" name="name" placeholder="What should I call you?" autocomplete="name" />
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-email">Email <span class="optional">(optional)</span></label>
            <p class="form-hint">Only needed if you would like a reply.</p>
            <input type="email" class="form-input" id="contact-email" name="email" placeholder="your@email.com" autocomplete="email" />
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-message">Message <span style="color: #c0392b;">*</span></label>
            <textarea class="form-textarea" id="contact-message" name="message" rows="7" placeholder="What is on your mind?" required></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-large" id="contact-submit">Send message</button>

          <div class="form-success" id="contact-success">
            <strong>Message received.</strong> Thank you for reaching out. If you left an email address, you will hear back within a few days.
          </div>

          <div class="form-error" id="contact-error">
            Something went wrong. You can also email directly at <a href="mailto:hellosaudade20@gmail.com">hellosaudade20@gmail.com</a> — that works just as well.
          </div>
        </form>
      </div>

      {# Right sidebar #}
      <aside class="contact-sidebar">
        <div class="contact-card">
          <p class="contact-card-title">Direct email</p>
          <a href="mailto:hellosaudade20@gmail.com" class="contact-email-link">hellosaudade20@gmail.com</a>
          <p style="margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-ink-muted); line-height: 1.6;">Prefer email? That works too. A real person reads and responds to every message.</p>
        </div>

        <div class="contact-card">
          <p class="contact-card-title">Want to share your story?</p>
          <p style="font-size: var(--text-sm); color: var(--color-ink-muted); line-height: 1.6; margin-bottom: var(--space-4);">If you are looking to submit a community story rather than send a general message, the story form has a dedicated space for that.</p>
          <a href="/stories/#submit" class="btn btn-outline btn-small">Go to story form</a>
        </div>
      </aside>

    </div>
  </div>
</div>

<script>
(function() {
  const form = document.getElementById("contact-form");
  const submitBtn = document.getElementById("contact-submit");
  const successMsg = document.getElementById("contact-success");
  const errorMsg = document.getElementById("contact-error");

  if (!form) return;

  form.addEventListener("submit", function(e) {
    e.preventDefault();

    const message = document.getElementById("contact-message").value.trim();
    if (!message) {
      if (window.showToast) showToast("Please write a message.", "error");
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";

    const formData = new FormData();
    formData.append("name", document.getElementById("contact-name").value.trim() || "Anonymous");
    formData.append("email", document.getElementById("contact-email").value.trim());
    formData.append("message", message);

    fetch("https://formspree.io/f/xlgypekv", {
      method: "POST",
      body: formData,
      headers: { "Accept": "application/json" }
    })
    .then(function(res) {
      if (res.ok) {
        form.reset();
        successMsg.classList.add("is-visible");
        submitBtn.style.display = "none";
      } else {
        throw new Error("Form error");
      }
    })
    .catch(function() {
      errorMsg.classList.add("is-visible");
      submitBtn.disabled = false;
      submitBtn.textContent = "Send message";
    });
  });
})();
</script>
