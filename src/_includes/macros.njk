{# Post card macro #}
{% macro postCard(post) %}
<a href="{{ post.url }}" class="card post-card" data-title="{{ post.data.title | lower }}" data-excerpt="{{ post.data.excerpt | lower }}" data-category="{{ post.data.category }}">
  {% if post.data.category %}
  <span class="tag tag--category">{{ post.data.category }}</span>
  {% endif %}
  <h3 class="card-title">{{ post.data.title }}</h3>
  {% if post.data.excerpt %}
  <p class="card-excerpt">{{ post.data.excerpt }}</p>
  {% endif %}
  <div class="card-meta">
    <time datetime="{{ post.date | isoDate }}">{{ post.date | formatDate }}</time>
    <span class="meta-sep">&middot;</span>
    <span>{{ post.templateContent | readingTime }}</span>
  </div>
</a>
{% endmacro %}

{# Story card macro #}
{% macro storyCard(story) %}
<a href="{{ story.url }}" class="card story-card" data-title="{{ story.data.title | lower }}" data-excerpt="{{ story.data.excerpt | lower }}" data-topic="{{ story.data.topic }}">
  {% if story.data.topic %}
  <span class="tag tag--topic">{{ story.data.topic }}</span>
  {% endif %}
  <h3 class="card-title">{{ story.data.title }}</h3>
  {% if story.data.excerpt %}
  <p class="card-excerpt">{{ story.data.excerpt }}</p>
  {% endif %}
  <div class="story-card-footer">
    <div class="author-row">
      <div class="author-avatar" aria-hidden="true">{{ story.data.author[0] if story.data.author else "A" }}</div>
      <div>
        <p class="author-name">{{ story.data.author if story.data.author else "Anonymous" }}</p>
        {% if story.data.details %}
        <p class="author-details">{{ story.data.details }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</a>
{% endmacro %}

{# Empty state macro #}
{% macro emptyState(heading, body) %}
<div class="empty-state">
  <div class="empty-state-icon" aria-hidden="true">✦</div>
  <h3>{{ heading }}</h3>
  <p>{{ body }}</p>
</div>
{% endmacro %}
